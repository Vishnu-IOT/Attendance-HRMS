RewriteEngine On
Options -MultiViews

# Force HTTPS (optional but safe)
RewriteCond %{HTTPS} off
RewriteRule ^ https://mykonnect.mpeoplesnet.com%{REQUEST_URI} [L,R=301]

# React Routing Fix
RewriteBase /

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]